# ── PostgreSQL ──
DB_USER=arpeteria
DB_PASSWORD=CHANGE_MOI_mot_de_passe_fort
DB_DATABASE=arpeteria

# ── Directus ──
DIRECTUS_SECRET=CHANGE_MOI_chaine_aleatoire_64_caracteres
DIRECTUS_ADMIN_EMAIL=conservateur@arpeteria.fr
DIRECTUS_ADMIN_PASSWORD=CHANGE_MOI_autre_mot_de_passe_fort
DIRECTUS_STATIC_TOKEN=CHANGE_MOI_token_lecture_seule_pour_le_build

# ── Domaines publics (docker-compose.yml : PUBLIC_URL/CORS_ORIGIN de Directus,
# et URL des fichiers/images embarquée dans le HTML statique au build de "web") ──
# Prod normale (Caddy en façade unique, voir docs/deploiement.md) : laisser les
# valeurs par défaut ci-dessous (arpeteria.fr) en ne définissant pas ces variables.
# Déploiement de test derrière un autre reverse proxy (ex. Nginx Proxy Manager) :
# renseigner ici le(s) nom(s) de domaine réellement utilisé(s).
# SITE_URL=https://arpeteria.fr
# DIRECTUS_PUBLIC_URL=https://admin.arpeteria.fr

# ── Scripts (scripts/bootstrap-schema.ts, scripts/seed.ts) ──
# URL Directus joignable depuis ta machine (hôte), pas l'URL interne Docker.
# Utiliser 127.0.0.1 plutôt que "localhost" : sur certains systèmes (Debian, systemd-resolved),
# Node résout "localhost" en ::1 (IPv6) en priorité, alors que Docker ne publie le port
# que sur 127.0.0.1 (IPv4) — la connexion échoue alors en ECONNREFUSED.
# Dev local : http://127.0.0.1:8055 · Prod : https://admin.arpeteria.fr
DIRECTUS_ADMIN_URL=http://127.0.0.1:8055

# ── Rebuild automatique (scripts/rebuild-webhook.mjs) ──
# Service tournant sur l'hôte (voir docs/deploiement.md, Étape 13bis) : reçoit un webhook
# depuis un Flow Directus à chaque publication et relance le build du site tout seul.
REBUILD_WEBHOOK_TOKEN=CHANGE_MOI_chaine_aleatoire_pour_le_webhook_de_rebuild
REBUILD_WEBHOOK_PORT=9002
