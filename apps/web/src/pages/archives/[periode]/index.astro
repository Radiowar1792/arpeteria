---
import Base from '../../../layouts/Base.astro';
import CarteOeuvre from '../../../components/CarteOeuvre.astro';
import BreadcrumbSchema from '../../../components/BreadcrumbSchema.astro';
import FiltresOeuvres from '../../../components/FiltresOeuvres.astro';
import { getCategories, getOeuvres, type Categorie, type Langue } from '../../../lib/directus.ts';
import { canonicalUrl } from '../../../lib/seo.ts';
import { ILLUSTRATIONS_PERIODES, illustrationCategorie } from '../../../lib/illustrations.ts';

export async function getStaticPaths() {
  const categories = await getCategories('archives');
  return categories.map((categorie) => ({
    params: { periode: categorie.slug },
    props: { categorie },
  }));
}

interface Props {
  categorie: Categorie;
}
const { categorie } = Astro.props;
const oeuvres = await getOeuvres({ categorieSlug: categorie.slug });
const langues = Array.from(new Set(oeuvres.map((o) => o.langue).filter((l): l is Langue => Boolean(l))));
const orthographes = Array.from(new Set(oeuvres.flatMap((o) => o.orthographes ?? [])));
const illustration = illustrationCategorie(categorie, ILLUSTRATIONS_PERIODES);
const filAriane = [
  { name: 'Accueil', url: canonicalUrl('/') },
  { name: 'Archives', url: canonicalUrl('/archives') },
  { name: categorie.nom, url: canonicalUrl(`/archives/${categorie.slug}`) },
];
---
<Base title={categorie.nom} description={categorie.description ?? undefined}>
  <BreadcrumbSchema items={filAriane} />
  <main id="contenu-principal">
    {illustration && (
      <div class="page-bandeau">
        <img src={illustration} alt="" width="960" height="640" loading="eager" decoding="async" />
      </div>
    )}
    <nav class="fil-ariane" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> › <a href="/archives">Archives</a>
    </nav>
    <h1>{categorie.nom}</h1>
    {categorie.description && <p>{categorie.description}</p>}

    {oeuvres.length > 0 ? (
      <>
        <FiltresOeuvres langues={langues} orthographes={orthographes} />
        <ul class="grille-oeuvres">
          {oeuvres.map((oeuvre) => (
            <li data-langue={oeuvre.langue ?? 'fr'} data-orthographes={(oeuvre.orthographes ?? []).join('|')}>
              <CarteOeuvre oeuvre={oeuvre} />
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p>Aucune œuvre publiée dans cette catégorie pour le moment.</p>
    )}
  </main>
</Base>
