---
import Base from '../layouts/Base.astro';
---
<Base
  title="Recherche"
  description="Recherche dans les archives et créations contemporaines d'Arpeteria."
>
  <main id="contenu-principal">
    <h1>Recherche</h1>
    <div id="recherche"></div>
  </main>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const cible = document.querySelector('#recherche');
      if (cible && window.PagefindUI) {
        cible.innerHTML = '';
        new window.PagefindUI({ element: '#recherche', showSubResults: true });
      }
    });
  </script>
</Base>
