---
import Base from '../../layouts/Base.astro';
import CarteOeuvre from '../../components/CarteOeuvre.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import { getOeuvres } from '../../lib/directus.ts';
import { slugifierMotCle } from '../../lib/motscles.ts';
import { canonicalUrl } from '../../lib/seo.ts';

export async function getStaticPaths() {
  const oeuvres = await getOeuvres();
  const parSlug = new Map<string, string>();

  for (const oeuvre of oeuvres) {
    for (const orthographe of oeuvre.orthographes ?? []) {
      const slug = slugifierMotCle(orthographe);
      if (slug && !parSlug.has(slug)) parSlug.set(slug, orthographe);
    }
  }

  return Array.from(parSlug.entries()).map(([slug, label]) => ({
    params: { orthographe: slug },
    props: { label },
  }));
}

interface Props {
  label: string;
}
const { label } = Astro.props;
const { orthographe } = Astro.params;

const toutesOeuvres = await getOeuvres();
const oeuvres = toutesOeuvres.filter((o) =>
  (o.orthographes ?? []).some((orth) => slugifierMotCle(orth) === orthographe)
);

const filAriane = [
  { name: 'Accueil', url: canonicalUrl('/') },
  { name: `Orthographe : ${label}`, url: canonicalUrl(`/orthographe/${orthographe}`) },
];
---
<Base
  title={`Orthographe : ${label}`}
  description={`Œuvres utilisant l'orthographe « ${label} » sur Arpeteria.`}
>
  <BreadcrumbSchema items={filAriane} />
  <main id="contenu-principal">
    <nav class="fil-ariane" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> › Orthographe
    </nav>
    <p class="kicker">Orthographe</p>
    <h1>{label}</h1>

    {oeuvres.length === 0 ? (
      <p>Aucune œuvre publiée pour cette orthographe.</p>
    ) : (
      <ul class="grille-oeuvres">
        {oeuvres.map((oeuvre) => (
          <li>
            <CarteOeuvre oeuvre={oeuvre} />
          </li>
        ))}
      </ul>
    )}
  </main>
</Base>
