---
import Base from '../layouts/Base.astro';
import CarteOeuvre from '../components/CarteOeuvre.astro';
import OrganizationSchema from '../components/OrganizationSchema.astro';
import { getOeuvres, getCategories, getRecommandations } from '../lib/directus.ts';
import { SECTIONS } from '../lib/taxonomies.ts';

const oeuvres = await getOeuvres();
const recentes = oeuvres.slice(0, 8);
const [categoriesArchives, categoriesContemporain, recommandations] = await Promise.all([
  getCategories('archives'),
  getCategories('contemporain'),
  getRecommandations(),
]);
const nombreCategories = categoriesArchives.length + categoriesContemporain.length;

const chiffres = [
  { valeur: oeuvres.length, label: oeuvres.length > 1 ? 'œuvres publiées' : 'œuvre publiée' },
  { valeur: nombreCategories, label: 'catégories' },
  { valeur: 2, label: 'sections : archives & contemporain' },
];
---
<Base title="Accueil">
  <OrganizationSchema />
  <main id="contenu-principal">
    <section class="hero">
      <p class="kicker kicker--centre">Culture savoyarde &amp; arpitane</p>
      <div class="hero__marque">
        <img class="hero__logo" src="/logo/logo-256.png" alt="" width="88" height="88" />
        <h1 class="hero__nom">Arpeteria</h1>
      </div>
      <p>
        Bibliothèque numérique de la culture savoyarde (arpitane) : archives historiques et
        créations contemporaines, réunies, documentées et mises en libre accès.
      </p>
      <div class="hero__actions">
        <a class="bouton bouton--principal" href="/archives">Explorer les archives</a>
        <a class="bouton bouton--secondaire" href="/contemporain">Créations contemporaines</a>
      </div>
    </section>

    <section aria-label="Arpeteria en chiffres">
      <div class="chiffres">
        {chiffres.map((chiffre) => (
          <div class="chiffres__item">
            <p class="chiffres__valeur">{chiffre.valeur}</p>
            <p class="chiffres__label">{chiffre.label}</p>
          </div>
        ))}
      </div>
      <p class="chiffres__lien"><a href="/collection">Voir le détail de la collection →</a></p>
    </section>

    <section class="mission">
      <div class="mission__texte">
        <p class="kicker">La mission</p>
        <h2>Sauvegarder et transmettre un patrimoine vivant</h2>
        <p>
          Beaucoup d'œuvres en langue et culture savoyarde restent difficiles à trouver : textes
          anciens dispersés, créations récentes peu visibles. Arpeteria les rassemble au même
          endroit, sous forme de PDF consultables et téléchargeables, complétés par des liens vers
          vidéos, enregistrements audio et sites recommandés.
        </p>
        <p>
          <a href="/a-propos">En savoir plus sur le projet →</a>
        </p>
      </div>
      <div class="mission__visuel" aria-hidden="true">
        <img src="/logo/logo-512.png" alt="" width="220" height="220" loading="lazy" />
      </div>
    </section>

    <section class="sections-cles">
      <a class="section-carte" href="/archives">
        <h2>{SECTIONS.archives.label}</h2>
        <p>{SECTIONS.archives.description}</p>
        <span class="section-carte__lien">Parcourir les archives →</span>
      </a>
      <a class="section-carte section-carte--contemporain" href="/contemporain">
        <h2>{SECTIONS.contemporain.label}</h2>
        <p>{SECTIONS.contemporain.description}</p>
        <span class="section-carte__lien">Découvrir les créations →</span>
      </a>
    </section>

    <section>
      <p class="kicker">Explorer autrement</p>
      <h2>Par le temps, la discipline… ou par les gens et les lieux</h2>
      <div class="sections-cles">
        <a class="section-carte section-carte--or" href="/personnages">
          <h2>Personnages</h2>
          <p>Figures savoyardes et arpitanes, historiques ou contemporaines.</p>
          <span class="section-carte__lien">Voir les personnages →</span>
        </a>
        <a class="section-carte section-carte--or" href="/lieux">
          <h2>Lieux patrimoniaux</h2>
          <p>Châteaux, villages et monuments qui font l'histoire de la Savoie.</p>
          <span class="section-carte__lien">Voir les lieux →</span>
        </a>
        <a class="section-carte section-carte--or" href="/actualites">
          <h2>Actualités</h2>
          <p>Annonces, contexte historique et carnets de recherche du conservateur.</p>
          <span class="section-carte__lien">Lire les actualités →</span>
        </a>
      </div>
    </section>

    {recentes.length > 0 && (
      <section class="section-oeuvres">
        <div class="section-oeuvres__entete">
          <h2>Dernières publications</h2>
          <a class="lien-voir-tout" href="/archives">Voir tout →</a>
        </div>
        <ul class="grille-oeuvres">
          {recentes.map((oeuvre) => (
            <li>
              <CarteOeuvre oeuvre={oeuvre} />
            </li>
          ))}
        </ul>
      </section>
    )}

    {recommandations.length > 0 && (
      <section class="teaser-recommandations">
        <h2>Envie d'aller plus loin ?</h2>
        <p>
          Découvre aussi les sites et ressources recommandés par le conservateur autour de la
          culture savoyarde et de l'arpitan.
        </p>
        <a class="bouton bouton--secondaire" href="/recommandations">Voir les recommandations</a>
      </section>
    )}
  </main>
</Base>
