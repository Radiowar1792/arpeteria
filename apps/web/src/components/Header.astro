---
import { getCategories } from '../lib/directus.ts';

const [categoriesArchives, categoriesContemporain] = await Promise.all([
  getCategories('archives'),
  getCategories('contemporain'),
]);

const menus = [
  { href: '/archives', label: 'Archives', categories: categoriesArchives },
  { href: '/contemporain', label: 'Contemporain', categories: categoriesContemporain },
];

const liens = [
  { href: '/actualites', label: 'Actualités' },
  { href: '/personnages', label: 'Personnages' },
  { href: '/lieux', label: 'Lieux' },
  { href: '/recommandations', label: 'Recommandations' },
  { href: '/recherche', label: 'Recherche' },
  { href: '/a-propos', label: 'À propos' },
];
---
<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/">
      <img class="site-header__logo" src="/logo/logo-256.png" alt="" width="44" height="44" />
      <span class="site-header__nom">Arpeteria</span>
    </a>

    <div class="site-header__outils">
      <button type="button" class="theme-bascule" id="bascule-theme" aria-label="Changer de thème clair/sombre">
        <svg class="theme-bascule__icone theme-bascule__icone--soleil" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 4a1 1 0 0 1-1-1V2a1 1 0 1 1 2 0v1a1 1 0 0 1-1 1Zm0 16a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1ZM4 12a1 1 0 0 1-1 1H2a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1Zm18 0a1 1 0 0 1-1 1h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1ZM5.64 18.36a1 1 0 0 1-1.42-1.42l.71-.7a1 1 0 0 1 1.41 1.41l-.7.71Zm11.31-11.31a1 1 0 0 1-1.41-1.41l.7-.71a1 1 0 1 1 1.42 1.42l-.71.7ZM5.64 5.64a1 1 0 0 1 1.41 0l.71.7a1 1 0 1 1-1.41 1.42l-.71-.71a1 1 0 0 1 0-1.41Zm11.31 11.31a1 1 0 0 1 1.42 0l.7.71a1 1 0 0 1-1.41 1.41l-.71-.7a1 1 0 0 1 0-1.42ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Z"
          />
        </svg>
        <svg class="theme-bascule__icone theme-bascule__icone--lune" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
        </svg>
      </button>

      <button
        type="button"
        class="site-header__bascule"
        id="bascule-menu"
        aria-expanded="false"
        aria-controls="nav-principale"
        aria-label="Ouvrir le menu"
      >
        <span class="site-header__barre"></span>
        <span class="site-header__barre"></span>
        <span class="site-header__barre"></span>
      </button>
    </div>

    <nav class="site-header__nav" id="nav-principale" aria-label="Navigation principale">
      {menus.map((menu) => (
        <div class="menu-deroulant">
          <div class="menu-deroulant__ligne">
            <a href={menu.href}>{menu.label}</a>
            {menu.categories.length > 0 && (
              <button
                type="button"
                class="menu-deroulant__bascule"
                aria-expanded="false"
                aria-label={`Afficher les catégories : ${menu.label}`}
              >
                <svg class="menu-deroulant__chevron" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M7 10l5 5 5-5H7Z" />
                </svg>
              </button>
            )}
          </div>
          {menu.categories.length > 0 && (
            <div class="menu-deroulant__panneau">
              <ul class="menu-deroulant__liste">
                {menu.categories.map((categorie) => (
                  <li>
                    <a href={`${menu.href}/${categorie.slug}`}>{categorie.nom}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      ))}
      {liens.map((lien) => <a href={lien.href}>{lien.label}</a>)}
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const bascule = document.getElementById('bascule-menu');
    const nav = document.getElementById('nav-principale');
    const header = document.querySelector('.site-header');

    if (bascule && nav && header && !bascule.dataset.pret) {
      bascule.dataset.pret = 'true';

      bascule.addEventListener('click', () => {
        const ouvert = nav.classList.toggle('site-header__nav--ouvert');
        bascule.setAttribute('aria-expanded', String(ouvert));
      });

      document.addEventListener('click', (evenement) => {
        if (!header.contains(evenement.target as Node)) {
          nav.classList.remove('site-header__nav--ouvert');
          bascule.setAttribute('aria-expanded', 'false');
        }
      });

      // Le header persiste entre les pages (transition:persist) : sans ça, le menu
      // resterait visuellement ouvert sur la page suivante après un clic sur un lien.
      nav.addEventListener('click', (evenement) => {
        if ((evenement.target as HTMLElement).closest('a')) {
          nav.classList.remove('site-header__nav--ouvert');
          bascule.setAttribute('aria-expanded', 'false');
        }
      });
    }

    const basculeTheme = document.getElementById('bascule-theme');
    if (basculeTheme && !basculeTheme.dataset.pret) {
      basculeTheme.dataset.pret = 'true';
      basculeTheme.addEventListener('click', () => {
        const actuel = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        const suivant = actuel === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', suivant);
        localStorage.setItem('arpeteria-theme', suivant);
      });
    }

    document.querySelectorAll<HTMLElement>('.menu-deroulant').forEach((menu) => {
      if (menu.dataset.pret) return;
      const boutonSousMenu = menu.querySelector<HTMLButtonElement>('.menu-deroulant__bascule');
      if (!boutonSousMenu) return;
      menu.dataset.pret = 'true';

      boutonSousMenu.addEventListener('click', () => {
        const ouvert = menu.classList.toggle('menu-deroulant--ouvert');
        boutonSousMenu.setAttribute('aria-expanded', String(ouvert));
      });
    });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
