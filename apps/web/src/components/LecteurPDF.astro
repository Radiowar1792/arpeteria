---
import { assetUrl } from '../lib/directus.ts';

interface Props {
  fichierId: string;
}
const { fichierId } = Astro.props;
const url = assetUrl(fichierId);
---
<div class="lecteur-pdf">
  <div class="lecteur-pdf__barre">
    <span class="lecteur-pdf__badge">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path
        fill="currentColor"
        d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6H6Zm7 1.5L18.5 9H14a1 1 0 0 1-1-1V3.5ZM8 13h2.2a2 2 0 1 1 0 4H9v2H8v-6Zm1 1v2h1.2a1 1 0 1 0 0-2H9Zm4-1h2c1.1 0 2 .9 2 2v2c0 1.1-.9 2-2 2h-2v-6Zm1 1v4h1a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1h-1Zm5-1h3v1h-2v1.5h1.8V16H19V19h-1v-6Z"
      /></svg>
      PDF
    </span>
    <div class="lecteur-pdf__actions">
      <a class="lecteur-pdf__action" href={url} target="_blank" rel="noopener">Plein écran</a>
      <a class="lecteur-pdf__action" href={`${url}?download`} download>Télécharger</a>
    </div>
  </div>
  <div class="lecteur-pdf__stage lecteur-pdf__stage--chargement" data-lecteur-pdf-stage data-src={url}>
    <iframe class="lecteur-pdf__cadre" src={url} title="Aperçu du PDF" data-lecteur-pdf-cadre></iframe>
    <div class="lecteur-pdf__erreur" data-lecteur-pdf-erreur>
      <p>L'aperçu met trop de temps à s'afficher. Le serveur est peut-être temporairement surchargé.</p>
      <div class="lecteur-pdf__erreur-actions">
        <button type="button" class="lecteur-pdf__action lecteur-pdf__action--bouton" data-lecteur-pdf-reessayer>
          Réessayer
        </button>
        <a class="lecteur-pdf__action" href={url} target="_blank" rel="noopener">Ouvrir dans un nouvel onglet</a>
      </div>
    </div>
  </div>
</div>

<script>
  const DELAI_TIMEOUT_MS = 15000;

  function initLecteursPDF() {
    document.querySelectorAll<HTMLElement>('[data-lecteur-pdf-stage]').forEach((stage) => {
      if (stage.dataset.lecteurPdfInit) return;
      stage.dataset.lecteurPdfInit = 'true';

      const cadre = stage.querySelector<HTMLIFrameElement>('[data-lecteur-pdf-cadre]');
      const bouton = stage.querySelector<HTMLButtonElement>('[data-lecteur-pdf-reessayer]');
      const src = stage.dataset.src ?? '';
      let minuteur: ReturnType<typeof setTimeout> | undefined;

      const surChargement = () => {
        window.clearTimeout(minuteur);
        stage.classList.remove('lecteur-pdf__stage--chargement', 'lecteur-pdf__stage--erreur');
      };

      const demarrer = () => {
        stage.classList.add('lecteur-pdf__stage--chargement');
        stage.classList.remove('lecteur-pdf__stage--erreur');
        window.clearTimeout(minuteur);
        minuteur = window.setTimeout(() => {
          stage.classList.remove('lecteur-pdf__stage--chargement');
          stage.classList.add('lecteur-pdf__stage--erreur');
        }, DELAI_TIMEOUT_MS);
      };

      cadre?.addEventListener('load', surChargement);
      bouton?.addEventListener('click', () => {
        if (!cadre) return;
        demarrer();
        cadre.src = 'about:blank';
        cadre.src = src;
      });

      demarrer();
    });
  }

  document.addEventListener('astro:page-load', initLecteursPDF);
</script>
