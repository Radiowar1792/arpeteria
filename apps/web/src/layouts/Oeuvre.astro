---
import Base from './Base.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import LecteurPDF from '../components/LecteurPDF.astro';
import LecteurVideo from '../components/LecteurVideo.astro';
import LienExterne from '../components/LienExterne.astro';
import CarteOeuvre from '../components/CarteOeuvre.astro';
import { assetUrl, getOeuvres, type Oeuvre } from '../lib/directus.ts';
import { canonicalUrl } from '../lib/seo.ts';
import { slugifierMotCle } from '../lib/motscles.ts';
import { LABELS_LANGUE } from '../lib/langues.ts';
import { LABELS_TYPE_MEDIA } from '../lib/typesMedia.ts';

interface Props {
  oeuvre: Oeuvre;
}
const { oeuvre } = Astro.props;
const url = canonicalUrl(`/oeuvre/${oeuvre.slug}`);
const image = oeuvre.couverture ? assetUrl(oeuvre.couverture.id, { width: 800, height: 600 }) : undefined;
const sectionLabel = oeuvre.section === 'archives' ? 'Archives' : 'Contemporain';

const oeuvresLiees = (
  await getOeuvres(
    oeuvre.categorie ? { categorieSlug: oeuvre.categorie.slug } : { section: oeuvre.section }
  )
)
  .filter((o) => o.id !== oeuvre.id)
  .slice(0, 4);
const filAriane = [
  { name: 'Accueil', url: canonicalUrl('/') },
  { name: sectionLabel, url: canonicalUrl(`/${oeuvre.section}`) },
  ...(oeuvre.categorie
    ? [
        {
          name: oeuvre.categorie.nom,
          url: canonicalUrl(`/${oeuvre.section}/${oeuvre.categorie.slug}`),
        },
      ]
    : []),
  { name: oeuvre.titre, url },
];

const referenceCitation = `${oeuvre.auteur || 'Anonyme'}${oeuvre.date_oeuvre ? ` (${oeuvre.date_oeuvre})` : ''}. « ${oeuvre.titre} ». Arpeteria — bibliothèque numérique de la culture savoyarde (arpitane).`;
const citation = `${referenceCitation} Disponible sur : ${url}`;
---
<Base title={oeuvre.titre} description={oeuvre.description ?? undefined} image={image}>
  <SchemaOrg oeuvre={oeuvre} url={url} image={image} />
  <BreadcrumbSchema items={filAriane} />
  <main id="contenu-principal" class="fiche-oeuvre">
    <nav class="fil-ariane" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> › <a href={`/${oeuvre.section}`}>{sectionLabel}</a>
      {oeuvre.categorie && (
        <>
          {' '}› <a href={`/${oeuvre.section}/${oeuvre.categorie.slug}`}>{oeuvre.categorie.nom}</a>
        </>
      )}
    </nav>

    {image && (
      <img
        class="fiche-oeuvre__couverture"
        src={image}
        alt=""
        width="800"
        height="600"
        decoding="async"
        transition:name={`couverture-${oeuvre.id}`}
      />
    )}

    <h1 lang={oeuvre.langue ?? 'fr'} transition:name={`titre-${oeuvre.id}`}>{oeuvre.titre}</h1>

    {oeuvre.orthographes && oeuvre.orthographes.length > 0 && (
      <ul class="orthographes" aria-label="Orthographes utilisées dans cette œuvre">
        {oeuvre.orthographes.map((orthographe) => (
          <li>
            <a class="orthographes__tag" href={`/orthographe/${slugifierMotCle(orthographe)}`}>
              {orthographe}
            </a>
          </li>
        ))}
      </ul>
    )}

    {/* Métadonnées pour les facettes de recherche Pagefind — non visibles, redondantes avec
        le fil d'Ariane/la visionneuse/l'attribut lang déjà affichés sur la page. */}
    <div style="display:none" aria-hidden="true">
      <span data-pagefind-filter="Section">{sectionLabel}</span>
      <span data-pagefind-filter="Type">{LABELS_TYPE_MEDIA[oeuvre.type_media]}</span>
      {oeuvre.langue && <span data-pagefind-filter="Langue">{LABELS_LANGUE[oeuvre.langue]}</span>}
      {oeuvre.categorie && <span data-pagefind-filter="Catégorie">{oeuvre.categorie.nom}</span>}
      {oeuvre.orthographes?.map((orthographe) => (
        <span data-pagefind-filter="Orthographe">{orthographe}</span>
      ))}
    </div>
    {oeuvre.auteur && <p class="fiche-oeuvre__auteur">{oeuvre.auteur}</p>}
    {oeuvre.date_oeuvre && <p class="fiche-oeuvre__date">{oeuvre.date_oeuvre}</p>}

    {oeuvre.description && (
      <div class="fiche-oeuvre__description" lang={oeuvre.langue ?? 'fr'} set:html={oeuvre.description} />
    )}

    {oeuvre.type_media === 'pdf' && oeuvre.fichier_pdf && (
      <LecteurPDF fichierId={oeuvre.fichier_pdf.id} />
    )}
    {oeuvre.type_media === 'video' && oeuvre.url_externe && (
      <LecteurVideo url={oeuvre.url_externe} titre={oeuvre.titre} />
    )}
    {oeuvre.type_media !== 'pdf' && oeuvre.type_media !== 'video' && oeuvre.url_externe && (
      <LienExterne type={oeuvre.type_media} url={oeuvre.url_externe} />
    )}

    {oeuvre.mots_cles && oeuvre.mots_cles.length > 0 && (
      <ul class="mots-cles">
        {oeuvre.mots_cles.map((mot) => (
          <li>
            <a href={`/mot-cle/${slugifierMotCle(mot)}`}>{mot}</a>
          </li>
        ))}
      </ul>
    )}

    <section class="citation">
      <p class="kicker">Citer cette œuvre</p>
      <blockquote class="citation__bloc">
        <p>{referenceCitation}</p>
        <p class="citation__url">
          Disponible sur : <a href={url}>{url}</a>
        </p>
      </blockquote>
      <div class="citation__actions">
        <button type="button" class="citation__bouton" id="bouton-citation" data-citation={citation}>
          Copier la citation
        </button>
        <span class="citation__note">La citation copiée inclut la date de consultation du jour.</span>
      </div>
    </section>

    {oeuvresLiees.length > 0 && (
      <section class="section-liee">
        <h2>À découvrir aussi</h2>
        <ul class="grille-oeuvres">
          {oeuvresLiees.map((liee) => (
            <li>
              <CarteOeuvre oeuvre={liee} />
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>
</Base>

<script>
  function initCitation() {
    const bouton = document.getElementById('bouton-citation');
    if (!bouton || bouton.dataset.pret) return;
    bouton.dataset.pret = 'true';

    bouton.addEventListener('click', async () => {
      const dateConsultation = new Date().toLocaleDateString('fr-FR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
      const texte = `${bouton.dataset.citation ?? ''} Consulté le ${dateConsultation}.`;
      try {
        await navigator.clipboard.writeText(texte);
        const original = bouton.textContent;
        bouton.textContent = 'Copié !';
        setTimeout(() => {
          bouton.textContent = original;
        }, 1800);
      } catch (e) {
        // silencieux : au pire l'utilisateur copie le texte à la main
      }
    });
  }

  document.addEventListener('astro:page-load', initCitation);
</script>
