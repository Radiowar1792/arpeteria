---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { canonicalUrl } from '../lib/seo.ts';

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const {
  title,
  description = 'Arpeteria — bibliothèque numérique de la culture savoyarde (arpitane).',
  image,
} = Astro.props;

const canonical = canonicalUrl(Astro.url.pathname);
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        try {
          var stocke = localStorage.getItem('arpeteria-theme');
          var theme = stocke || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Arpeteria</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Arpeteria — dernières publications" href="/rss.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#171310" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
    />
    {import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
      <script
        is:inline
        defer
        src={`${import.meta.env.PUBLIC_UMAMI_URL}/script.js`}
        data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
      ></script>
    )}
    <ClientRouter />
  </head>
  <body>
    <a class="lien-evitement" href="#contenu-principal">Aller au contenu</a>
    <div class="barre-progression" id="barre-progression"></div>
    <Header />
    <slot />
    <Footer />
    <button
      type="button"
      class="bouton-haut"
      id="bouton-haut"
      aria-label="Retour en haut de page"
    >
      ↑
    </button>
    <script>
      function initInteractionsPage() {
        const barre = document.getElementById('barre-progression');
        const boutonHaut = document.getElementById('bouton-haut');
        if (!barre || !boutonHaut) return;

        const onScroll = () => {
          const hauteur = document.documentElement.scrollHeight - window.innerHeight;
          const progres = hauteur > 0 ? (window.scrollY / hauteur) * 100 : 0;
          barre.style.width = `${progres}%`;
          boutonHaut.classList.toggle('bouton-haut--visible', window.scrollY > 480);
        };

        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        boutonHaut.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      document.addEventListener('astro:page-load', initInteractionsPage);
    </script>
  </body>
</html>
