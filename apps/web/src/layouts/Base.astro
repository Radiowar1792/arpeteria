---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Arpeteria — bibliothèque numérique de la culture savoyarde" } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Arpeteria</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
