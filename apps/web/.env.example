# Utilisé par `npm run dev` / `npm run build` lancés directement (hors Docker).
# En Docker, ces valeurs sont passées via les build args de docker-compose.yml.

DIRECTUS_URL=http://127.0.0.1:8055
DIRECTUS_PUBLIC_URL=http://127.0.0.1:8055
DIRECTUS_STATIC_TOKEN=

# Statistiques Umami (facultatif) — laisser vide en dev local pour ne pas injecter le script.
PUBLIC_UMAMI_URL=
PUBLIC_UMAMI_WEBSITE_ID=
